# Copy this file to .env.local and fill in your values

# Your deployed Cloudflare Worker URL (leave blank to use localhost:8787 during dev)
NEXT_PUBLIC_WORKER_URL=https://maps-scraper-api.<your-subdomain>.workers.dev

# Scraper.tech API key (set in Cloudflare Worker secrets, NOT here)
# Run: npx wrangler secret put SCRAPER_API_KEY --cwd worker
